# Google Drive OAuth (Google Cloud Console → APIs & Services → Credentials)
# Scope used: drive.appdata (non-sensitive, no app verification required)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Dropbox OAuth (Dropbox App Console → App key)
# Access type: App folder only
VITE_DROPBOX_CLIENT_ID=your-dropbox-app-key
